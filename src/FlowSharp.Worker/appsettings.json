{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data/flowsharp.db"
  },
  "Database": {
    "Provider": "Sqlite",
    "ApplyMigrationsOnStartup": true
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Worker": {
    "MaxConcurrency": 5
  },
  "RateLimit": {
    "Enabled": true,
    "RunsPerMinutePerUser": 60
  },
  "BlobStorage": {
    "Enabled": false,
    "Directory": "App_Data/blobs",
    "ThresholdBytes": 65536
  },
  "OpenTelemetry": {
    "Enabled": false,
    "OtlpEndpoint": ""
  },
  "Security": {
    "CredentialEncryptionKey": "sU7uc/MSLu+Aib+HM5nrQXwPifVu+UYwbmu6rfwtYBU="
  },
  "HttpNodes": {
    "Exposure": "Local",
    "BlockPrivateNetworks": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
