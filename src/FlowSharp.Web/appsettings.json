{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data/flowsharp.db"
  },
  "Database": {
    "Provider": "Sqlite",
    "ApplyMigrationsOnStartup": true
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Worker": {
    "RunInWebProcess": true,
    "MaxConcurrency": 5
  },
  "RateLimit": {
    "Enabled": true,
    "RunsPerMinutePerUser": 60
  },
  "Security": {
    "CredentialEncryptionKey": "sU7uc/MSLu+Aib+HM5nrQXwPifVu+UYwbmu6rfwtYBU="
  },
  "Identity": {
    "RequireConfirmedAccount": false
  },
  "Email": {
    "Host": "",
    "Port": 587,
    "EnableSsl": true,
    "User": "",
    "Password": "",
    "From": "",
    "FromName": "FlowSharp"
  },
  "HttpNodes": {
    "Exposure": "Local",
    "BlockPrivateNetworks": false
  },
  "Executions": {
    "SaveData": "All",
    "MaxCount": 1000,
    "MaxAgeDays": 30
  },
  "BlobStorage": {
    "Enabled": true,
    "Directory": "App_Data/blobs",
    "ThresholdBytes": 65536
  },
  "OpenTelemetry": {
    "Enabled": false,
    "OtlpEndpoint": ""
  },
  "Rag": {
    "DatabaseDirectory": "App_Data/rag"
  },
  "Plugins": {
    "Path": "plugins",
    "OfficialMarketplaceUrl": "https://github.com/FlowSharp/plugins"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}