@using Microsoft.AspNetCore.Identity
@using FlowSharp.Infrastructure.Identity

@inject SignInManager<ApplicationUser> SignInManager

<MudNavMenu Rounded="true" Dense="true" Margin="Margin.Dense" Color="Color.Primary" Class="account-nav-menu">
    <MudNavLink Href="Account/Manage" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Person">Profil</MudNavLink>
    <MudNavLink Href="Account/Manage/Email" Icon="@Icons.Material.Filled.AlternateEmail">E-posta</MudNavLink>
    <MudNavLink Href="Account/Manage/ChangePassword" Icon="@Icons.Material.Filled.Lock">Sifre</MudNavLink>
    @if (hasExternalLogins)
    {
        <MudNavLink Href="Account/Manage/ExternalLogins" Icon="@Icons.Material.Filled.Link">Harici girisler</MudNavLink>
    }
    <MudNavLink Href="Account/Manage/TwoFactorAuthentication" Icon="@Icons.Material.Filled.Security">Iki asamali dogrulama</MudNavLink>
    <MudNavLink Href="Account/Manage/Passkeys" Icon="@Icons.Material.Filled.Fingerprint">Passkey</MudNavLink>
    <MudNavLink Href="Account/Manage/PersonalData" Icon="@Icons.Material.Filled.AdminPanelSettings">Kisisel veriler</MudNavLink>
</MudNavMenu>

@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}
