@page "/workflows/designer"
@page "/workflows/designer/{WorkflowId:guid}"
@page "/workflows/designer/{WorkflowId:guid}/executions/{ExecutionId:guid}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using FlowSharp.Domain.Nodes
@using FlowSharp.Domain.Credentials
@using FlowSharp.Domain.Security

@attribute [Authorize(Policy = AppPermissions.WorkflowsWrite)]

<PageTitle>@workflowName</PageTitle>

<div class="nwf-designer @(IsReadOnly ? "readonly-exec" : "") @(running ? "running" : "")">
    <div class="nwf-toolbar">
        <a class="btn btn-ghost btn-sm" href="workflows">← @L["nav.workflows"]</a>
        <input class="name-input" @bind="workflowName" @bind:event="oninput" disabled="@IsReadOnly" />
        <div class="spacer"></div>
        <label class="toggle-wrap">
            @L["home.active"]
            <span class="switch">
                <input type="checkbox" checked="@isActive" @onchange="ToggleActive" disabled="@IsReadOnly" />
                <span class="slider"></span>
            </span>
        </label>
        @if (!IsReadOnly)
        {
            <button class="btn btn-success btn-sm" @onclick="ExecuteAsync" disabled="@(nodes.Count == 0 || running || !CanRunWorkflow)">
                @(running ? L["designer.running"] : $"▶ {L["common.run"]}")
            </button>
            <button class="btn btn-primary btn-sm" @onclick="SaveAsync">@L["common.save"]</button>
        }
    </div>
    @if (IsReadOnly)
    {
        <div class="execution-banner">
            <span><i class="bi bi-clock-history"></i> &nbsp;<strong>@L["designer.banner.viewing_history"]</strong> (@L["designer.banner.readonly"])</span>
            <a class="btn btn-ghost btn-sm" href="/executions">← @L["designer.banner.back_to_history"]</a>
        </div>
    }

    <div class="nwf-canvas" id="nwf-canvas" tabindex="0">
        <div class="nwf-world">
            <svg class="nwf-edges"></svg>

            @foreach (var node in nodes)
            {
                var def = Definition(node.NodeKey);
                if (node.NodeKey == "core.stickyNote")
                {
                    var title = GetParam(node, "title") is { Length: > 0 } t ? t : "Grup Başlığı";
                    var notes = GetParam(node, "notes");
                    var color = GetParam(node, "color") is { Length: > 0 } c ? c : "green";
                    var width = GetParam(node, "width") is { Length: > 0 } w ? w : "400";
                    var isCollapsed = GetParam(node, "collapsed") == "true";
                    var fullHeight = GetParam(node, "height") is { Length: > 0 } h ? h : "250";
                    var height = isCollapsed ? "52" : fullHeight;

                    <div class="nwf-node nwf-sticky-note @color @(node.InstanceId == selectedId ? "selected" : "") @(colorPickerNodeId == node.InstanceId ? "picking" : "")"
                         id="node-@node.InstanceId"
                         data-collapsed="@(isCollapsed ? "true" : "false")"
                         data-full-h="@fullHeight"
                         style="left:@(node.X)px; top:@(node.Y)px; width:@(width)px; height:@(height)px; min-height: 52px;">
                        <div class="nwf-sticky-head">
                            <input class="nwf-sticky-title-input" value="@title" @oninput='e => SetParam(node, "title", e.Value?.ToString())' disabled="@IsReadOnly" />
                            
                            <div class="nwf-sticky-controls">
                                <div class="nwf-sticky-color-wrap">
                                    <span class="nwf-sticky-color-current color-dot @color"
                                          title="Renk"
                                          @onclick='() => colorPickerNodeId = colorPickerNodeId == node.InstanceId ? null : node.InstanceId'
                                          @onclick:stopPropagation></span>
                                    @if (colorPickerNodeId == node.InstanceId)
                                    {
                                        <div class="nwf-sticky-color-pop">
                                            @foreach (var col in new[] { "green", "blue", "yellow", "red", "purple" })
                                            {
                                                var activeCol = col;
                                                <span class="color-dot @activeCol @(color == activeCol ? "active" : "")"
                                                      @onclick='() => { SetParam(node, "color", activeCol); colorPickerNodeId = null; }'
                                                      @onclick:stopPropagation></span>
                                            }
                                        </div>
                                    }
                                </div>

                                <button class="nwf-sticky-collapse-btn" @onclick="() => ToggleStickyCollapse(node)">
                                    <i class="bi @(isCollapsed ? "bi-chevron-down" : "bi-chevron-up")"></i>
                                </button>
                                
                                @if (!IsReadOnly)
                                {
                                    <button class="nwf-sticky-del-btn" @onclick="() => RemoveNode(node.InstanceId)" @onclick:stopPropagation>✕</button>
                                }
                            </div>
                        </div>
                        
                        @if (!isCollapsed)
                        {
                            <textarea class="nwf-sticky-textarea" value="@notes" @oninput='e => SetParam(node, "notes", e.Value?.ToString())' disabled="@IsReadOnly"></textarea>
                            
                            @if (!IsReadOnly)
                            {
                                <div class="nwf-sticky-resize-handle"></div>
                            }
                        }
                    </div>
                }
                else
                {
                    var inputPorts = def?.InputPorts ?? (node.NodeKey.Contains("trigger") ? Array.Empty<NodePort>() : [NodePort.Main]);
                    // Cikis portlari instance parametrelerine gore degisebilir (IHasDynamicOutputs).
                    var outputPorts = NodeCatalog.ResolveOutputs(node.NodeKey, node.Parameters);
                    var mainIns = inputPorts.Select((p, idx) => (Port: p, Idx: idx)).Where(x => x.Port.Type == NodePortType.Main).ToList();
                    var subIns = inputPorts.Select((p, idx) => (Port: p, Idx: idx)).Where(x => x.Port.Type != NodePortType.Main).ToList();
                    var mainOuts = outputPorts.Select((p, idx) => (Port: p, Idx: idx)).Where(x => x.Port.Type == NodePortType.Main).ToList();
                    var subOuts = outputPorts.Select((p, idx) => (Port: p, Idx: idx)).Where(x => x.Port.Type != NodePortType.Main).ToList();
                    var rows = Math.Max(mainIns.Count, mainOuts.Count);
                    var minHeight = Math.Max(84, 16 + rows * 20 + 14);

                    <div class="nwf-node @(node.InstanceId == selectedId ? "selected" : "") status-@node.Status"
                         id="node-@node.InstanceId" style="left:@(node.X)px; top:@(node.Y)px; min-height:@(minHeight)px">

                        @if (!string.IsNullOrEmpty(node.Status))
                        {
                            var statusCls = node.Status switch
                            {
                                "Succeeded" => "success",
                                "Failed" => "failed",
                                "Running" => "running",
                                _ => ""
                            };
                            var statusIcon = node.Status switch
                            {
                                "Succeeded" => "bi-check",
                                "Failed" => "bi-x",
                                "Running" => "bi-arrow-repeat nwf-spin",
                                _ => ""
                            };
                            @if (!string.IsNullOrEmpty(statusCls) && !string.IsNullOrEmpty(statusIcon))
                            {
                                <div class="nwf-node-exec-status @statusCls">
                                    <i class="bi @statusIcon"></i>
                                </div>
                            }
                        }

                        @if (IsPinned(node))
                        {
                            <div class="nwf-node-pin" title="Veri sabitlendi (pin)">
                                <i class="bi bi-pin-angle-fill"></i>
                            </div>
                        }

                        @for (var k = 0; k < mainIns.Count; k++)
                        {
                            <div class="nwf-port in" id="port-@node.InstanceId-in-@mainIns[k].Idx"
                                 data-node="@node.InstanceId" data-port="@mainIns[k].Idx" data-port-type="main"
                                 style="top:@(PortTop(k, mainIns.Count))px"></div>
                        }
                        @for (var k = 0; k < subIns.Count; k++)
                        {
                            <div class="nwf-port in sub-in" id="port-@node.InstanceId-in-@subIns[k].Idx"
                                 data-node="@node.InstanceId" data-port="@subIns[k].Idx" data-port-type="sub"
                                 style="left:@(BottomX(k, subIns.Count))px">
                                <span class="nwf-port-label sub">@subIns[k].Port.Label</span>
                            </div>
                        }

                        <div class="nwf-node-head">
                            <div class="nwf-node-icon" style="background:@(def?.Color ?? "#6b7280")">
                                @if (def is not null && !string.IsNullOrWhiteSpace(def.Icon))
                                {
                                    <i class="bi @GetIconClass(def.Icon)"></i>
                                }
                                else
                                {
                                    @Initials(node.Name)
                                }
                            </div>
                            <div class="nwf-node-title">
                                <strong>@node.Name</strong>
                                <span>@node.Category</span>
                            </div>
                        </div>

                        <div class="nwf-node-foot">
                            @if (!IsReadOnly)
                            {
                                <button class="nwf-node-del" @onclick="() => RemoveNode(node.InstanceId)" @onclick:stopPropagation>✕</button>
                            }
                        </div>

                        @for (var k = 0; k < mainOuts.Count; k++)
                        {
                            <div class="nwf-port out" id="port-@node.InstanceId-out-@mainOuts[k].Idx"
                                 data-node="@node.InstanceId" data-port="@mainOuts[k].Idx" data-port-type="main"
                                 style="top:@(PortTop(k, mainOuts.Count))px">
                                @if (mainOuts.Count > 1)
                                {
                                    <span class="nwf-port-label">@mainOuts[k].Port.Label</span>
                                }
                            </div>
                        }
                        @for (var k = 0; k < subOuts.Count; k++)
                        {
                            <div class="nwf-port out sub-out" id="port-@node.InstanceId-out-@subOuts[k].Idx"
                                 data-node="@node.InstanceId" data-port="@subOuts[k].Idx" data-port-type="sub"
                                 style="left:@(BottomX(k, subOuts.Count))px"></div>
                        }
                    </div>
                }
            }
        </div>

        @if (nodes.Count == 0)
        {
            <div class="nwf-canvas-empty">
                <div>
                    <h2>@L["designer.empty.title"]</h2>
                    <p>@L["designer.empty.summary"]</p>
                </div>
            </div>
        }

        @if (!IsReadOnly)
        {
            <button class="nwf-add-fab" title="@L["designer.node.add"]" @onclick="OpenPalette">+</button>
        }

        <div class="nwf-controls">
            <button title="@L["designer.controls.zoom_in"]" @onclick='() => Module("zoomIn")'>+</button>
            <button title="@L["designer.controls.zoom_out"]" @onclick='() => Module("zoomOut")'>−</button>
            <button title="@L["designer.controls.fit_view"]" @onclick='() => Module("fitView")'>⤢</button>
            <button title="@L["designer.controls.reset_view"]" @onclick='() => Module("resetView")'>⟲</button>
        </div>

        @if (HasChatTrigger)
        {
            <button class="nwf-chat-fab @(showChat ? "active" : "")" title="@L["designer.chat.assistant"]" @onclick="() => showChat = !showChat">
                <i class="bi @(showChat ? "bi-x-lg" : "bi-chat-dots-fill")"></i>
            </button>
        }
    </div>
</div>

@if (showPalette)
{
    <div class="nwf-drawer">
        <div class="nwf-drawer-head">
            <h2>@L["designer.node.add"]</h2>
            <button class="nwf-drawer-close" @onclick="() => showPalette = false">✕</button>
        </div>
        <div class="nwf-drawer-body">
            <input class="palette-search" placeholder="@L["designer.node.search"]" @bind="paletteSearch" @bind:event="oninput" />
            @foreach (var group in FilteredCatalog())
            {
                var open = IsCatOpen(group.Key);
                <div class="palette-cat @(open ? "open" : "")" @onclick="() => ToggleCat(group.Key)">
                    <span><span class="chev">▶</span> &nbsp;@group.Key</span>
                    <span class="palette-cat">@group.Count()</span>
                </div>
                @if (open)
                {
                    @if (group.Any(def => GetSubCategory(def) is not null))
                    {
                        var subGroups = group.GroupBy(def => GetSubCategory(def)!).OrderBy(g => g.Key);
                        @foreach (var subGroup in subGroups)
                        {
                            var subOpen = IsSubCatOpen(subGroup.Key);
                            <div class="palette-cat palette-subcat-row @(subOpen ? "open" : "")" @onclick="() => ToggleSubCat(subGroup.Key)">
                                <span>
                                    <span class="chev">▶</span>
                                    &nbsp;@subGroup.Key
                                </span>
                                <span class="palette-cat">@subGroup.Count()</span>
                            </div>
                            @if (subOpen)
                            {
                                @foreach (var def in subGroup)
                                {
                                    <div class="palette-item" @onclick="() => AddNode(def)">
                                        <span class="pi-icon" style="background:@def.Color">
                                            @if (!string.IsNullOrWhiteSpace(def.Icon))
                                            {
                                                <i class="bi @GetIconClass(def.Icon)"></i>
                                            }
                                            else
                                            {
                                                @Initials(def.DisplayName)
                                            }
                                        </span>
                                        <span class="pi-text">
                                            <strong>@def.DisplayName</strong>
                                            <span>@def.Description</span>
                                        </span>
                                    </div>
                                }
                            }
                        }
                    }
                    else
                    {
                        @foreach (var def in group)
                        {
                            <div class="palette-item" @onclick="() => AddNode(def)">
                                <span class="pi-icon" style="background:@def.Color">
                                    @if (!string.IsNullOrWhiteSpace(def.Icon))
                                    {
                                        <i class="bi @GetIconClass(def.Icon)"></i>
                                    }
                                    else
                                    {
                                        @Initials(def.DisplayName)
                                    }
                                </span>
                                <span class="pi-text">
                                    <strong>@def.DisplayName</strong>
                                    <span>@def.Description</span>
                                </span>
                            </div>
                        }
                    }
                }
            }
        </div>
    </div>
}

@if (openNode is not null)
{
    var def = Definition(openNode.NodeKey);
    <div class="nwf-modal-backdrop" @onclick="CloseNdv">
        <div class="nwf-modal" @onclick:stopPropagation="true">
            <div class="nwf-modal-head">
                <div class="nwf-node-icon" style="background:@(def?.Color ?? "#6b7280")">
                    @if (def is not null && !string.IsNullOrWhiteSpace(def.Icon))
                    {
                        <i class="bi @GetIconClass(def.Icon)"></i>
                    }
                    else
                    {
                        @Initials(openNode.Name)
                    }
                </div>
                <div>
                    <strong>@openNode.Name</strong>
                    <div class="sub">@def?.Description</div>
                </div>
                <div class="sp"></div>
                @if (!IsReadOnly)
                {
                    <button class="btn btn-success btn-sm" @onclick="() => ExecuteUpToAsync(openNode)" disabled="@running"
                            title="Bu node'u ve atalarini calistir (downstream calismaz)">▶ @L["common.run"]</button>
                }
                <button class="nwf-drawer-close" @onclick="CloseNdv">✕</button>
            </div>

            <div class="ndv-grid">
                <div class="ndv-col io input">
                    <h3>@L["designer.ndv.input"]</h3>
                    @{
                        var inputSources = InputSourceNodes(openNode);
                        if (inputSources.Count > 0 && (inputSelectedNodeId is null || inputSources.All(s => s.InstanceId != inputSelectedNodeId)))
                        {
                            inputSelectedNodeId = inputSources[0].InstanceId;
                        }
                    }
                    @if (inputSources.Count == 0)
                    {
                        <div class="ndv-empty">@L["designer.ndv.no_upstream_data"]</div>
                    }
                    else
                    {
                        <select class="select" value="@inputSelectedNodeId"
                                @onchange="e => inputSelectedNodeId = e.Value?.ToString()">
                            @foreach (var s in inputSources)
                            {
                                <option value="@s.InstanceId" selected="@(s.InstanceId == inputSelectedNodeId)">@s.Name</option>
                            }
                        </select>
                        <div class="ndv-input-hint">Bir parametreye tıkla, sonra aşağıdaki bir alana tıkla → ifade otomatik eklenir.</div>
                        <div class="ndv-fields">
                            @foreach (var f in InputFields(inputSelectedNodeId))
                            {
                                <div class="ndv-field-row" style="padding-left:@(6 + f.Depth * 14)px"
                                     title="@f.Path tıkla → ekle" @onclick="() => InsertInputExpression(f.Path)">
                                    <span class="ndv-field-key">@f.Label</span>
                                    <span class="ndv-field-val">@f.Preview</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="ndv-col params">
                    <div class="field">
                        <label>@L["designer.ndv.node_name"]</label>
                        <input class="input" value="@openNode.Name" @onchange="e => RenameNode(openNode, e.Value?.ToString())" disabled="@IsReadOnly" />
                    </div>

                    @if (def is not null && (def.Key == "webhook.trigger" || def.Key == "whatsapp.trigger"))
                    {
                        var webhookUrlReady = workflow is not null;
                        var isWhatsApp = def.Key == "whatsapp.trigger";
                        <div class="field">
                            <label>@(isWhatsApp ? "Callback URL" : L["designer.ndv.webhook_url"])</label>
                            <div style="display:flex; gap:8px; align-items:center">
                                <input class="input" readonly value="@WebhookUrl(openNode)" style="font-family:'JetBrains Mono',Consolas,monospace; font-size:12px" />
                                <button class="btn btn-ghost btn-sm" title="Kopyala" @onclick="() => CopyAsync(WebhookUrl(openNode))">📋</button>
                            </div>
                            @if (!webhookUrlReady)
                            {
                                <div class="expr-hint expr-err">@L["designer.ndv.webhook_save_first"]</div>
                            }
                            @if (isWhatsApp)
                            {
                                <div class="hint">Meta panelinde WhatsApp webhook'una bu URL'i Callback URL, yukarıdaki Verify Token'ı da doğrulama anahtarı olarak girin.</div>
                            }
                            else
                            {
                                <div class="hint">Bu adrese @(GetParam(openNode, "method") is { Length: > 0 } m ? m : "POST") istegi gelince workflow tetiklenir.</div>
                            }
                        </div>
                    }

                    @if (def is not null && def.Category == NodeCategory.Database
                        && !openNode.NodeKey.EndsWith(".connection", StringComparison.Ordinal)
                        && !HasUpstreamConnection(openNode))
                    {
                        <div class="field">
                            <div class="expr-hint expr-err">
                                ⚠ Bu node bir database connection node'una bağlı değil.
                                Önce <strong>Connection</strong> (→ <strong>Table</strong>) node'una bağlayın.
                            </div>
                        </div>
                    }

                    @if (def is not null && def.Parameters.Count > 0)
                    {
                        @foreach (var p in def.Parameters.Where(p => IsParamVisible(openNode, p)))
                        {
                            <div class="field" @onfocusin="() => insertTarget = AppendToParam(p.Key)">
                                <label>@p.Label @(p.IsRequired ? "*" : "")</label>
                                @if (p.Type == NodeParameterType.Credential)
                                {
                                    <select class="select" value="@GetParam(openNode, p.Key)"
                                            @onchange="e => SetParam(openNode, p.Key, e.Value?.ToString())" disabled="@IsReadOnly">
                                        <option value="">— @L["designer.ndv.select_credential"] —</option>
                                        @foreach (var c in CredentialsFor(def))
                                        {
                                            <option value="@c.Id">@c.Name (@c.Type)</option>
                                        }
                                    </select>
                                    @if (!IsReadOnly)
                                    {
                                        <button class="btn btn-ghost btn-sm" style="margin-top:6px"
                                                @onclick="() => StartCredAdd(def, p.Key)">+ @L["designer.ndv.add_new_credential"]</button>
                                    }

                                    @if (credAddOpen && credAddParamKey == p.Key)
                                    {
                                        <div class="cred-add">
                                            <div class="field"><label>@L["credentials.form.name"]</label>
                                                <input class="input" @bind="credAddName" placeholder="Ornek: Prod" /></div>
                                            @foreach (var f in credAddFields)
                                            {
                                                <div class="cred-row">
                                                    @if (f.FromSchema)
                                                    {
                                                        <label class="cred-key-label" style="align-self:center">@f.Label</label>
                                                    }
                                                    else
                                                    {
                                                        <input class="input" placeholder="@L["credentials.form.key_placeholder"]" @bind="f.Key" />
                                                    }
                                                    @if (f.FieldType == CredentialFieldType.Boolean)
                                                    {
                                                        <label class="input" style="display:flex; align-items:center; gap:8px">
                                                            <input type="checkbox"
                                                                   checked="@string.Equals(f.Value, "true", StringComparison.OrdinalIgnoreCase)"
                                                                   @onchange='e => f.Value = e.Value is true ? "true" : "false"' />
                                                            <span>@(string.Equals(f.Value, "true", StringComparison.OrdinalIgnoreCase) ? "true" : "false")</span>
                                                        </label>
                                                    }
                                                    else
                                                    {
                                                        <input class="input"
                                                               type="@(f.FieldType == CredentialFieldType.Secret ? "password" : f.FieldType == CredentialFieldType.Number ? "number" : "text")"
                                                               placeholder="@L["credentials.form.value_placeholder"]" @bind="f.Value" />
                                                    }
                                                    @if (!f.FromSchema)
                                                    {
                                                        <button class="btn btn-danger btn-sm" @onclick="() => credAddFields.Remove(f)">−</button>
                                                    }
                                                </div>
                                            }
                                            <button class="btn btn-ghost btn-sm cred-add-field" @onclick="() => credAddFields.Add(new())">+ @L["designer.ndv.add_field"]</button>
                                            <div class="cred-actions">
                                                <button class="btn btn-ghost" @onclick="() => credAddOpen = false">@L["common.cancel"]</button>
                                                <button class="btn btn-primary" @onclick="() => SaveCredAddAsync(def, p.Key)">@L["common.save"]</button>
                                            </div>
                                        </div>
                                    }
                                }
                                else if (p.Key == "columnsJson" && (def.Key is "db.insert" or "db.update" or "db.upsert"))
                                {
                                    // Upsert'te key (PK) kolonlari gerekir; insert/update'te PK gizlenir (otomatik/where).
                                    var showPk = def.Key == "db.upsert";
                                    var mapKeys = ColumnMapKeys().Where(k => showPk || !k.IsPk).ToList();
                                    var colLoading = dynLoading.Contains("columnsJson");
                                    <div class="ndv-colmap">
                                        <div style="display:flex; gap:6px; align-items:center; margin-bottom:6px">
                                            <span class="hint" style="flex:1">Tablo kolonlarini doldur (bos kolon atlanir).</span>
                                            <button class="btn btn-ghost btn-sm" title="Kolonlari yenile" disabled="@(IsReadOnly || colLoading)"
                                                    @onclick='() => LoadDynamicOptionsAsync(openNode, "columnsJson")'>
                                                @(colLoading ? "…" : "↻")
                                            </button>
                                        </div>
                                        @if (mapKeys.Count == 0)
                                        {
                                            <div class="expr-hint expr-err">Kolon bulunamadi. Tabloyu sec ve ↻ ile yenile (bir kez calistirmak gerekebilir).</div>
                                        }
                                        @foreach (var (colName, _) in mapKeys)
                                        {
                                            var colVal = columnValues.TryGetValue(colName, out var cv) ? cv : "";
                                            var colPrev = PreviewExpression(openNode, colVal);
                                            <div class="colmap-row" @onfocusin:stopPropagation="true" @onfocusin="() => insertTarget = AppendToColumn(colName)">
                                                <label class="colmap-key" title="@colName">@colName</label>
                                                <input class="input expr-@colPrev.State" value="@colVal" placeholder="deger veya {{ ifade }}"
                                                       @oninput="e => { columnValues[colName] = e.Value?.ToString() ?? string.Empty; SyncColumnValues(openNode); }"
                                                       disabled="@IsReadOnly" />
                                            </div>
                                            @if (colPrev.State == "valid")
                                            {
                                                <div class="expr-hint expr-ok">= @colPrev.Message</div>
                                            }
                                            else if (colPrev.State == "invalid")
                                            {
                                                <div class="expr-hint expr-err">@colPrev.Message</div>
                                            }
                                        }
                                    </div>
                                }
                                else if (def.Key == "db.ensureTable" && p.Key == "columns")
                                {
                                    <div class="ensure-columns">
                                        @foreach (var (col, idx) in ensureColumns.Select((c, i) => (c, i)))
                                        {
                                            <div style="display:flex; gap:6px; margin-bottom:4px; align-items:center">
                                                <input class="input" style="flex:1" placeholder="kolon adi" value="@col.Name"
                                                       @oninput="e => { col.Name = e.Value?.ToString() ?? string.Empty; SyncEnsureColumns(openNode); }" disabled="@IsReadOnly" />
                                                <input class="input" list="ensure-col-types" style="width:120px" placeholder="TEXT" value="@col.Type"
                                                       @oninput="e => { col.Type = e.Value?.ToString() ?? string.Empty; SyncEnsureColumns(openNode); }" disabled="@IsReadOnly" />
                                                <label style="display:flex; gap:3px; align-items:center; font-weight:400" title="Primary Key">
                                                    <input type="checkbox" checked="@col.Pk"
                                                           @onchange="e => { col.Pk = (bool)(e.Value ?? false); SyncEnsureColumns(openNode); }" disabled="@IsReadOnly" />PK</label>
                                                <label style="display:flex; gap:3px; align-items:center; font-weight:400" title="NOT NULL">
                                                    <input type="checkbox" checked="@col.NotNull"
                                                           @onchange="e => { col.NotNull = (bool)(e.Value ?? false); SyncEnsureColumns(openNode); }" disabled="@IsReadOnly" />NN</label>
                                                <button class="btn btn-danger btn-sm" title="Sil" disabled="@IsReadOnly"
                                                        @onclick="() => { ensureColumns.RemoveAt(idx); SyncEnsureColumns(openNode); }">−</button>
                                            </div>
                                        }
                                        <datalist id="ensure-col-types">
                                            <option>TEXT</option><option>INTEGER</option><option>REAL</option>
                                            <option>NUMERIC</option><option>BLOB</option>
                                        </datalist>
                                        @if (!IsReadOnly)
                                        {
                                            <button class="btn btn-ghost btn-sm" @onclick="() => { ensureColumns.Add(new()); SyncEnsureColumns(openNode); }">+ Kolon</button>
                                        }
                                    </div>
                                }
                                else if (p.Type is NodeParameterType.Text or NodeParameterType.Json or NodeParameterType.Code)
                                {
                                    var prev = PreviewExpression(openNode, GetParam(openNode, p.Key));
                                    <textarea class="textarea expr-@prev.State" value="@GetParam(openNode, p.Key)"
                                              @oninput="e => SetParam(openNode, p.Key, e.Value?.ToString())" disabled="@IsReadOnly"></textarea>
                                    @if (p.Type == NodeParameterType.Json && !IsReadOnly)
                                    {
                                        <button class="btn btn-ghost btn-sm" title="JSON'u düzenle (beautify)"
                                                @onclick="() => SetParam(openNode, p.Key, FlowSharp.Application.Json.FlowJson.Beautify(GetParam(openNode, p.Key)))">
                                            { } Düzenle
                                        </button>
                                    }
                                    @if (prev.State == "valid")
                                    {
                                        <div class="expr-hint expr-ok">= @prev.Message</div>
                                    }
                                    else if (prev.State == "invalid")
                                    {
                                        <div class="expr-hint expr-err">@prev.Message</div>
                                    }
                                }
                                else if (p.Type == NodeParameterType.File)
                                {
                                    <InputFile OnChange="e => OnFileSelectedAsync(openNode, p.Key, e)" disabled="@IsReadOnly" />
                                    @if (FileName(GetParam(openNode, p.Key)) is { } fn)
                                    {
                                        <div class="hint">Secili: <strong>@fn</strong>
                                            <button class="btn btn-ghost btn-sm" @onclick="() => SetParam(openNode, p.Key, string.Empty)">@L["common.clear"]</button>
                                        </div>
                                    }
                                }
                                else if (p.Type == NodeParameterType.Boolean)
                                {
                                    <select class="select" value="@GetParam(openNode, p.Key)"
                                            @onchange="e => SetParam(openNode, p.Key, e.Value?.ToString())" disabled="@IsReadOnly">
                                        <option value="false">false</option>
                                        <option value="true">true</option>
                                    </select>
                                }
                                else if (p.Type == NodeParameterType.Select && p.Options is not null)
                                {
                                    <select class="select" value="@GetParam(openNode, p.Key)"
                                            @onchange="e => SetParam(openNode, p.Key, e.Value?.ToString())" disabled="@IsReadOnly">
                                        @foreach (var opt in p.Options)
                                        {
                                            <option value="@opt">@opt</option>
                                        }
                                    </select>
                                }
                                else if (p.Type == NodeParameterType.MultiSelect && p.Options is not null)
                                {
                                    var sel = MultiSelectValues(GetParam(openNode, p.Key));
                                    <div class="nwf-multiselect" style="display:flex; flex-direction:column; gap:4px">
                                        @foreach (var opt in p.Options)
                                        {
                                            <label style="display:flex; gap:6px; align-items:center; font-weight:400">
                                                <input type="checkbox" checked="@sel.Contains(opt)" disabled="@IsReadOnly"
                                                       @onchange="e => ToggleMultiSelect(openNode, p.Key, p.Options, opt, (bool)(e.Value ?? false))" />
                                                <span>@opt</span>
                                            </label>
                                        }
                                    </div>
                                }
                                else if (p.DynamicOptions)
                                {
                                    var cur = GetParam(openNode, p.Key);
                                    var opts = dynOptions.TryGetValue(p.Key, out var list) ? list : null;
                                    var loading = dynLoading.Contains(p.Key);
                                    <div style="display:flex; gap:6px; align-items:center">
                                        <select class="select" value="@cur"
                                                @onchange="e => SetParam(openNode, p.Key, e.Value?.ToString())" disabled="@IsReadOnly">
                                            <option value="" selected="@string.IsNullOrWhiteSpace(cur)">— Seç —</option>
                                            @if (opts is not null)
                                            {
                                                @foreach (var opt in opts)
                                                {
                                                    <option value="@opt.Value" selected="@(opt.Value == cur)">@opt.Label</option>
                                                }
                                            }
                                            @if (!string.IsNullOrWhiteSpace(cur) && (opts is null || !opts.Any(o => o.Value == cur)))
                                            {
                                                <option value="@cur" selected>@cur</option>
                                            }
                                        </select>
                                        <button class="btn btn-ghost btn-sm" title="Yenile"
                                                @onclick="() => LoadDynamicOptionsAsync(openNode, p.Key)"
                                                disabled="@(IsReadOnly || loading)">
                                            @(loading ? "…" : "↻")
                                        </button>
                                    </div>
                                    @if (dynErrors.TryGetValue(p.Key, out var dErr) && !string.IsNullOrWhiteSpace(dErr))
                                    {
                                        <div class="expr-hint expr-err">@dErr</div>
                                    }
                                }
                                else
                                {
                                    var prev = PreviewExpression(openNode, GetParam(openNode, p.Key));
                                    <input class="input expr-@prev.State" type="@(p.Type == NodeParameterType.Secret ? "password" : "text")"
                                           value="@GetParam(openNode, p.Key)"
                                           @oninput="e => SetParam(openNode, p.Key, e.Value?.ToString())" disabled="@IsReadOnly" />
                                    @if (prev.State == "valid")
                                    {
                                        <div class="expr-hint expr-ok">= @prev.Message</div>
                                    }
                                    else if (prev.State == "invalid")
                                    {
                                        <div class="expr-hint expr-err">@prev.Message</div>
                                    }
                                }
                                @if (!string.IsNullOrWhiteSpace(p.HelpText))
                                {
                                    <div class="hint">@p.HelpText</div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="hint">@L["designer.ndv.no_parameters"]</p>
                    }
                </div>

                <div class="ndv-col io output">
                    <h3>@L["designer.ndv.output"]</h3>
                    @if (!IsReadOnly)
                    {
                        <div style="display:flex; gap:6px; margin-bottom:6px; align-items:center">
                            @if (IsPinned(openNode))
                            {
                                <span class="hint" style="flex:1">📌 Veri sabitlendi — bu node calismaz, sabit veri akar.</span>
                                <button class="btn btn-ghost btn-sm" @onclick="() => UnpinNode(openNode)">Pin'i kaldir</button>
                            }
                            else if (NodeOutput(openNode.InstanceId) is { Error: null })
                            {
                                <span class="hint" style="flex:1"></span>
                                <button class="btn btn-ghost btn-sm" title="Bu ciktiyi ornek veri olarak sabitle"
                                        @onclick="() => PinNode(openNode)">📌 Pin'le</button>
                            }
                        </div>
                    }
                    @if (NodeOutput(openNode.InstanceId) is { } output)
                    {
                        @if (!string.IsNullOrWhiteSpace(output.Error))
                        {
                            <div class="ndv-data expr-err"><pre>@output.Error</pre></div>
                        }
                        else
                        {
                            <div class="hint" style="margin-bottom:6px">@output.ItemCount @L["designer.ndv.items"]</div>
                            <div class="ndv-data"><pre>@output.Json</pre></div>
                        }
                    }
                    else
                    {
                        <div class="ndv-empty">@L["designer.ndv.run_to_see_output"]</div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (showChat)
{
    <div class="nwf-chat">
        <div class="nwf-chat-head">
            <div class="nwf-chat-brand">
                <div class="nwf-chat-avatar">
                    <i class="bi bi-robot"></i>
                    <span class="status-dot online"></span>
                </div>
                <div class="nwf-chat-title-group">
                    <span class="nwf-chat-title">@L["designer.chat.title"]</span>
                    <span class="nwf-chat-subtitle">@L["designer.chat.subtitle"]</span>
                </div>
            </div>
            <button class="nwf-chat-close-btn" @onclick="() => showChat = false" title="@L["common.close"]">✕</button>
        </div>
        <div class="nwf-chat-msgs">
            @foreach (var msg in chatMessages)
            {
                <div class="nwf-chat-msg @(msg.IsUser ? "user" : "bot")">@msg.Text</div>
            }
            @if (!CanSendChat)
            {
                <div class="nwf-chat-msg bot">@L["designer.chat.not_connected"]</div>
            }
            @if (ShowTyping)
            {
                <div class="nwf-chat-msg bot typing">
                    <span class="dot"></span>
                    <span class="dot"></span>
                    <span class="dot"></span>
                </div>
            }
        </div>
        <div class="nwf-chat-input">
            <input class="nwf-chat-text-input" placeholder="@L["designer.chat.input_placeholder"]" @bind="chatInput" @bind:event="oninput"
                   @onkeydown="OnChatKeyDown" disabled="@(chatBusy || !CanSendChat)" />
            <button class="nwf-chat-send-btn" @onclick="SendChatAsync" disabled="@(chatBusy || !CanSendChat || string.IsNullOrWhiteSpace(chatInput))" title="@L["common.send"]">
                <i class="bi bi-send-fill"></i>
            </button>
        </div>
    </div>
}


