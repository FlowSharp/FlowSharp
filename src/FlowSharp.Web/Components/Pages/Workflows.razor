@page "/workflows"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using FlowSharp.Domain.Security
@using FlowSharp.Domain.Workflows
@attribute [Authorize(Policy = AppPermissions.WorkflowsRead)]

<PageTitle>@L["nav.workflows"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="Fsharp-page">
    <MudStack Spacing="4">
        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="Fsharp-page-head">
            <div>
                <MudText Typo="Typo.h4" Class="Fsharp-title">@L["nav.workflows"]</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">@L["workflows.summary"]</MudText>
            </div>
            @if (canWrite)
            {
                <MudButton Href="workflows/designer" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add">
                    @L["home.new_workflow"]
                </MudButton>
            }
        </MudStack>

        @if (workflows is null)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (workflows.Count == 0)
        {
            <MudPaper Class="Fsharp-empty Fsharp-surface" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6">@L["workflows.empty.title"]</MudText>
                <MudText Color="Color.Secondary">@L["workflows.empty.summary"]</MudText>
                @if (canWrite)
                {
                    <MudButton Href="workflows/designer" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add">
                        @L["workflows.empty.open_designer"]
                    </MudButton>
                }
            </MudPaper>
        }
        else if (isAdmin)
        {
            @if (MineWorkflows.Any())
            {
                <MudText Typo="Typo.subtitle1" Class="mb-2">@L["workflows.section.mine"]</MudText>
                @WorkflowTable(MineWorkflows, showOwner: false)
            }
            @if (OtherWorkflows.Any())
            {
                <MudText Typo="Typo.subtitle1" Class="mt-6 mb-2">@L["workflows.section.others"]</MudText>
                @WorkflowTable(OtherWorkflows, showOwner: true)
            }
        }
        else
        {
            @WorkflowTable(workflows, showOwner: false)
        }
    </MudStack>
</MudContainer>

@code {
    private RenderFragment WorkflowTable(IEnumerable<Workflow> items, bool showOwner) =>
        @<MudTable Items="items" Hover="true" Elevation="0" Class="Fsharp-surface" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>@L["nav.workflows"]</MudTh>
                <MudTh>@L["workflows.status.active"]</MudTh>
                <MudTh>v</MudTh>
                @if (showOwner)
                {
                    <MudTh>@L["common.owner"]</MudTh>
                }
                <MudTh Style="text-align:right">@L["common.edit"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@L["nav.workflows"]">
                    <MudText Typo="Typo.body1">@context.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@(string.IsNullOrWhiteSpace(context.Description) ? L["workflows.no_description"] : context.Description)</MudText>
                </MudTd>
                <MudTd DataLabel="@L["workflows.status.active"]">
                    <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                        @(context.IsActive ? L["workflows.status.active"] : L["workflows.status.inactive"])
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="v">v@(context.Version)</MudTd>
                @if (showOwner)
                {
                    <MudTd DataLabel="@L["common.owner"]">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@OwnerLabel(context)</MudText>
                    </MudTd>
                }
                <MudTd Style="text-align:right">
                    @if (canWrite)
                    {
                        <MudIconButton Href="@($"workflows/designer/{context.Id}")" Icon="@Icons.Material.Filled.Edit" title="@L["common.edit"]" Size="Size.Small" />
                    }
                    @if (canExecute)
                    {
                        <MudIconButton Color="Color.Success"
                                       Icon="@Icons.Material.Filled.PlayArrow"
                                       title="@L["common.run"]" Size="Size.Small"
                                       Disabled="@(runningId == context.Id)" OnClick="() => RunAsync(context.Id)" />
                    }
                    @if (canWrite)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" title="@L["common.delete"]" Size="Size.Small" OnClick="() => DeleteAsync(context.Id)" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>;
}
