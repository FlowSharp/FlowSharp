@page "/credentials"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using FlowSharp.Application.Abstractions
@using FlowSharp.Domain.Security
@attribute [Authorize(Policy = AppPermissions.CredentialsManage)]

<PageTitle>@L["nav.credentials"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="Fsharp-page">
    <MudStack Spacing="4">
        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="Fsharp-page-head">
            <div>
                <MudText Typo="Typo.h4" Class="Fsharp-title">@L["nav.credentials"]</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">@L["credentials.summary"]</MudText>
            </div>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" OnClick="StartCreate">
                @L["credentials.new"]
            </MudButton>
        </MudStack>

        @if (items is null)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (items.Count == 0)
        {
            <MudPaper Class="Fsharp-empty Fsharp-surface" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.Key" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6">@L["credentials.empty.title"]</MudText>
                <MudText Color="Color.Secondary">@L["credentials.empty.summary"]</MudText>
            </MudPaper>
        }
        else if (isAdmin)
        {
            @if (MineCredentials.Any())
            {
                <MudText Typo="Typo.subtitle1" Class="mb-2">@L["credentials.section.mine"]</MudText>
                @CredentialTable(MineCredentials, showOwner: false)
            }
            @if (OtherCredentials.Any())
            {
                <MudText Typo="Typo.subtitle1" Class="mt-6 mb-2">@L["credentials.section.others"]</MudText>
                @CredentialTable(OtherCredentials, showOwner: true)
            }
        }
        else
        {
            @CredentialTable(items, showOwner: false)
        }
    </MudStack>
</MudContainer>

@code {
    private RenderFragment CredentialTable(IEnumerable<CredentialSummary> rows, bool showOwner) =>
        @<MudTable Items="rows" Hover="true" Elevation="0" Class="Fsharp-surface" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>@L["credentials.form.name"]</MudTh>
                <MudTh>@L["credentials.form.type"]</MudTh>
                @if (showOwner)
                {
                    <MudTh>@L["common.owner"]</MudTh>
                }
                <MudTh Style="text-align:right">@L["common.edit"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@L["credentials.form.name"]"><MudText Typo="Typo.body1">@context.Name</MudText></MudTd>
                <MudTd DataLabel="@L["credentials.form.type"]">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Type</MudChip>
                </MudTd>
                @if (showOwner)
                {
                    <MudTd DataLabel="@L["common.owner"]">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@OwnerLabel(context)</MudText>
                    </MudTd>
                }
                <MudTd Style="text-align:right">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" title="@L["common.edit"]" Size="Size.Small" OnClick="() => EditAsync(context.Id)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" title="@L["common.delete"]" Size="Size.Small" OnClick="() => DeleteAsync(context.Id)" />
                </MudTd>
            </RowTemplate>
        </MudTable>;
}

@if (editing)
{
    <MudDrawer Open="true"
               Anchor="Anchor.Right"
               Variant="DrawerVariant.Temporary"
               Width="420px"
               Class="Fsharp-edit-drawer">
        <MudStack Class="pa-5" Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h6">@(form.Id is null ? L["credentials.new"] : L["credentials.edit"])</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Cancel" />
            </MudStack>

            <MudTextField @bind-Value="form.Name" Label="@L["credentials.form.name"]" Placeholder="@L["credentials.form.name_placeholder"]" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="form.Type" Label="@L["credentials.form.type"]" Placeholder="@L["credentials.form.type_placeholder"]" Variant="Variant.Outlined" />

            <MudText Typo="Typo.subtitle2">@L["credentials.form.fields"]</MudText>
            @foreach (var field in fields)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudTextField @bind-Value="field.Key" Placeholder="@L["credentials.form.key_placeholder"]" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    <MudTextField @bind-Value="field.Value" Placeholder="@L["credentials.form.value_placeholder"]" InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Error" OnClick="() => fields.Remove(field)" />
                </MudStack>
            }
            <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="() => fields.Add(new FieldRow())">
                @L["credentials.form.add_field"]
            </MudButton>

            <MudStack Row="true" Spacing="1">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveAsync">@L["common.save"]</MudButton>
                <MudButton Variant="Variant.Text" OnClick="Cancel">@L["common.cancel"]</MudButton>
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <MudAlert Severity="Severity.Error">@message</MudAlert>
            }
        </MudStack>
    </MudDrawer>
}
